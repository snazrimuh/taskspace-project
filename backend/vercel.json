{
  "version": 2,
  "installCommand": "npm install --no-package-lock",
  "buildCommand": "npx prisma generate && npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.js": {
      "memory": 1024,
      "maxDuration": 30,
      "includeFiles": "dist/**,prisma/schema.prisma,node_modules/.prisma/**,node_modules/@prisma/client/**"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}
